{
  "name": "filesync-kubo",
  "version": "0.1.7",
  "private": false,
  "type": "module",
  "description": "Private IPFS-based file sync service",
  "license": "MIT",
  "main": "./dist/core/main.js",
  "bin": {
    "filesync-kubo": "bin/filesync-kubo.js"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "docs",
    "scripts"
  ],
  "keywords": [
    "filesync",
    "ipfs",
    "kubo",
    "p2p",
    "sync"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/core/main.js",
    "dev": "tsx src/core/main.ts",
    "test": "vitest run",
    "test:integration": "vitest run tests/multi-node.integration.test.ts",
    "test:e2e:pre:docker": "bash scripts/e2e-pre-docker.sh",
    "test:e2e:pre:npm": "bash scripts/e2e-pre-npm.sh",
    "test:e2e:post:docker": "bash scripts/e2e-post-docker.sh",
    "test:e2e:post:npm": "bash scripts/e2e-post-npm.sh",
    "pre-release": "npm run build && npm test && docker build -t filesync-kubo:local . && npm run test:e2e:pre:docker && npm run test:e2e:pre:npm",
    "post-release": "npm run test:e2e:post:docker && npm run test:e2e:post:npm",
    "publish:pack": "node scripts/publish-pack.mjs",
    "publish:npm": "npm publish",
    "publish:npm:dry-run": "npm publish --dry-run",
    "publish:github-package": "node scripts/publish-github-package.mjs",
    "release:check": "npm run build && npm test && npm run publish:npm:dry-run",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@fastify/static": "^8.3.0",
    "better-sqlite3": "^11.10.0",
    "chokidar": "^3.6.0",
    "fastify": "^5.6.1",
    "minimatch": "^10.0.3",
    "pino": "^9.11.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
